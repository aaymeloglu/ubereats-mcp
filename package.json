{
  "name": "ubereats-mcp",
  "version": "0.1.0",
  "description": "Unofficial Uber Eats MCP server. Browse restaurants and populate your cart from past orders via any MCP client.",
  "type": "module",
  "bin": {
    "ubereats-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["mcp", "ubereats", "uber-eats", "model-context-protocol"],
  "author": "Andy Aymeloglu",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "impit": "0.13.0",
    "playwright": "1.59.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
